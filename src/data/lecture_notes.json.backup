    "eca5f407-3690-4df7-a9b2-56d535e6e0f7": {
      "id": "eca5f407-3690-4df7-a9b2-56d535e6e0f7",
      "filename": "eca5f407-3690-4df7-a9b2-56d535e6e0f7_Unit 2.7 Escalation of commitment (2025).pdf",
      "original_name": "Unit 2.7 Escalation of commitment (2025).pdf",
      "file_size": 1427876,
