  {
    "id": "rubric-1775747189629",
    "title": "Comp 4900 Seminar Reflection",
    "description": "Write a reflection report",
    "questions": [
      {
        "id": "q-1775746947332",
        "title": "Write a reflection report",
        "description": "WHAT? What have you learned through this seminar? What stands out to you, feels new to you, excites you, or challenges you?\n\nWHY? Why does this learning matter? Why does it stand out to you? Why is it important - to you personally or in the bigger picture?\n\nHOW? What will you do from here? How will you take this learning with you? Does this learning change your perspective, your career goals, or your interests?",
        "minScore": 0,
        "maxScore": 30,
        "modelAnswer": "",
        "criteria": [
          {
            "id": "crit-1775746972124",
            "name": "Clarity and Relevance",
            "scoreLevels": [
              {
                "id": "sl-1775746984714",
                "scoreRange": "8-10",
                "description": "Excellent: The language is clear and expressive. The reader can create a mental picture of the situation being described. Abstract concepts are explained accurately. The reflection shows tremendous thought and effort. The learning experience being reflected upon is relevant and meaningful",
                "minPoints": 8,
                "maxPoints": 10
              },
              {
                "id": "sl-1775746992693",
                "scoreRange": "4-7",
                "description": "Pass: Minor, infrequent lapses in clarity. Abstract concepts are explained fairly accurately. The reflections show some thought and effort. Student makes attempts to demonstrate relevance, but the relevance is unclear in reference to learning goals.",
                "minPoints": 4,
                "maxPoints": 7
              },
              {
                "id": "sl-1775747013864",
                "scoreRange": "0-3",
                "description": "Fail: There are frequent lapses in clarity. Concepts are either not discussed or are presented inaccurately. The reflections show poor thought and effort. Most of the reflection is irrelevant to student and/or learning goals.",
                "minPoints": 0,
                "maxPoints": 3
              }
            ]
          },
          {
            "id": "crit-1775747071569",
            "name": "Analysis and Self-Criticism",
            "scoreLevels": [
              {
                "id": "sl-1775747087391",
                "scoreRange": "8-10",
                "description": "The reflection moves beyond simple description of the experience to an analysis of how the experience contributed to student understanding of self, others, and/or other concepts. It demonstrates ability of the student to question their own biases, stereotypes, preconceptions, and/or assumptions and define new modes of thinking as a result",
                "minPoints": 8,
                "maxPoints": 10
              },
              {
                "id": "sl-1775747097937",
                "scoreRange": "4-7",
                "description": "The reflection demonstrates student attempts to analyze the experience to understanding of self, but analysis lacks depth. It demonstrates ability of the student to question their own biases, stereotypes, preconceptions. New modes of thinking are not evident.",
                "minPoints": 4,
                "maxPoints": 7
              },
              {
                "id": "sl-1775747107770",
                "scoreRange": "0-3",
                "description": "Student makes attempts at applying the learning experience to understanding of self, others, and/or seminar concepts but fails to demonstrate depth of analysis. There is some attempt at self-criticism, but the self-reflection fails to demonstrate a new awareness of personal biases, etc.",
                "minPoints": 0,
                "maxPoints": 3
              }
            ]
          },
